{# Docker Deployment Summary Template #}
{# Displays a summary of successful and failed Docker deployments #}
{% if groups is defined and 'docker_deployed' in groups and groups['docker_deployed']|length > 0 %}
Successfully deployed ({{ groups['docker_deployed']|length }}):
{% for host in groups['docker_deployed']|sort %}
✅ {{ host }}
{% endfor %}
{% else %}
No successful deployments to report.
{% endif %}

{% if groups is defined and 'docker_failed' in groups and groups['docker_failed']|length > 0 %}
Failed deployments ({{ groups['docker_failed']|length }}):
{% for host in groups['docker_failed']|sort %}
❌ {{ host }}
{% endfor %}
{% else %}
No failed deployments to report.
{% endif %}