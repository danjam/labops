{# System Updates Summary Template #}
{# Displays a summary of successful and failed system updates #}
{% if groups is defined and 'ubuntu_updated' in groups and groups['ubuntu_updated']|length > 0 %}
Successfully updated ({{ groups['ubuntu_updated']|length }}):
{% for host in groups['ubuntu_updated']|sort %}
✅ {{ host }}
{% endfor %}
{% endif %}

{% if groups is defined and 'ubuntu_failed' in groups and groups['ubuntu_failed']|length > 0 %}
Failed updates ({{ groups['ubuntu_failed']|length }}):
{% for host in groups['ubuntu_failed']|sort %}
❌ {{ host }}
{% endfor %}
{% endif %}